# Anthropic Claude API キー（翻訳・清書に使用）
# https://console.anthropic.com でAPIキーを取得してください
# 未設定の場合は deep-translator（Google翻訳）にフォールバックします
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# Whisper モデルサイズ（デフォルト: medium）
# tiny / base / small / medium / large-v3
# 大きいほど精度が上がるが処理時間・メモリが増える
WHISPER_MODEL=large-v3

# 翻訳バックエンド: "claude" または "google"
# claude: Claude API を使用（高品質、要APIキー）
# google: deep-translator（無料、精度やや低め）
TRANSLATION_BACKEND=google

# デフォルト声優（female / male）
DEFAULT_VOICE=female

# TTS バックエンド: "edge"（デフォルト）または "voicevox"（高品質・要VOICEVOX起動）
TTS_BACKEND=edge

# VOICEVOX エンジンURL（TTS_BACKEND=voicevox の場合）
VOICEVOX_URL=http://localhost:50021

# VOICEVOX 話速（1.0=標準、1.1=少し速め推奨）
VOICEVOX_SPEED=1.1

# サーバーポート
PORT=8000
